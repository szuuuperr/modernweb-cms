# Production env for docker-compose.prod.yml.
# Copy to .env.production on the VPS and fill in. NEVER commit the real file.
#
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- domain ---
DOMAIN="api.modernwebid.com"
APP_URL="https://api.modernwebid.com"

# --- database (never exposed on the host; only the app container reaches it) ---
MYSQL_ROOT_PASSWORD=""      # generate: openssl rand -base64 32
MYSQL_DATABASE="modernweb_cms"

# --- secrets: generate fresh, never reuse the dev values ---
# openssl rand -base64 48
JWT_SECRET=""
JWT_REFRESH_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- storage ---
STORAGE_DRIVER="cloudinary"
CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"

# --- email (form notifications); leave SMTP_HOST empty to disable ---
# If SMTP_HOST is set, SMTP_FROM is required and the app refuses to start
# without it. Use an address on a domain you control, and give that domain
# SPF + DKIM records — otherwise the mail is delivered to spam.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@modernwebid.com"

# --- tuning ---
CONTENT_CACHE_TTL="60"
CONTENT_RATE_LIMIT="120"
CONTENT_RATE_TTL_MS="60000"
PREVIEW_TOKEN_TTL="1h"

# --- seed (only for the very first deploy; remove afterwards) ---
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
