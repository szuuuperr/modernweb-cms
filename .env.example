# allowPublicKeyRetrieval is needed for MySQL 8's caching_sha2_password over a
# plain (non-TLS) socket — i.e. the docker dev database. Drop it in production
# and use TLS: retrieving the key from an unverified server is MITM-able.
DATABASE_URL="mysql://root:root@localhost:3307/modernweb_cms?allowPublicKeyRetrieval=true"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=3000
APP_URL="http://localhost:3000"
UPLOAD_DIR="uploads"

# Origins allowed to send the refresh cookie (comma-separated, admin panel).
# Every other origin keeps open, cookie-less access to the public Content API.
ADMIN_ORIGINS="http://localhost:3000"
# Set false only for plain-HTTP local dev. SameSite=none *requires* secure=true.
COOKIE_SECURE="false"
# "lax" works when the panel and the API are the same site (cms./api. of the
# same domain). Use "none" when the panel is on a different registrable domain,
# e.g. a *.vercel.app preview deployment.
COOKIE_SAMESITE="lax"

# Rate limit for the public Content API (per API key, or per IP when anonymous)
CONTENT_RATE_LIMIT=120
CONTENT_RATE_TTL_MS=60000

# Storage: "local" (default) or "cloudinary"
STORAGE_DRIVER="local"
# Cloudinary — either CLOUDINARY_URL alone, or the three discrete vars below
# CLOUDINARY_URL="cloudinary://<api_key>:<api_secret>@<cloud_name>"
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Cache for the public Content API.
# Unset REDIS_URL falls back to an in-memory cache (fine for dev/single node).
# REDIS_URL="redis://localhost:6379"
CONTENT_CACHE_TTL=60

# Draft preview tokens (signed with JWT_SECRET)
PREVIEW_TOKEN_TTL="1h"

# Form notification email. Leave SMTP_HOST empty to log instead of sending.
# Setting SMTP_HOST makes SMTP_FROM required (the app refuses to start without
# it) — a sender on a domain you do not control just lands in spam.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@modernwebid.com"

# Set to the number of proxy hops (e.g. 1 behind nginx) so req.ip is the real
# client. Leave empty when there is no proxy — otherwise clients can spoof it.
TRUST_PROXY=""

SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123"

# Owner website Halwa Travel — platformRole NONE, jadi seluruh izinnya datang
# dari role Owner. Dipakai untuk menguji RBAC: super admin melewati
# PermissionsGuard sepenuhnya, jadi login sebagai dia tidak menguji apa pun.
# Hanya berlaku saat user dibuat pertama kali; mengubahnya tidak me-reset
# password akun yang sudah ada.
SEED_OWNER_EMAIL="owner@halwatravel.com"
SEED_OWNER_PASSWORD="owner123"
